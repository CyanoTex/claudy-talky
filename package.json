{
  "name": "claudy-talky",
  "version": "0.4.0",
  "description": "Let Claude Code CLI talk to Codex CLI, Gemini CLI, and local agents through a shared broker",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "broker": "bun broker.ts",
    "server": "bun server.ts",
    "operator": "bun operator.ts",
    "setup": "bun setup.ts install cli --scope user",
    "setup:project": "bun setup.ts install cli --scope project",
    "setup:all": "bun setup.ts install all --scope user",
    "server:codex": "bun codex-server.ts",
    "server:google": "bun google-server.ts",
    "server:gemini": "bun google-server.ts",
    "agents": "bun cli.ts agents",
    "example:http-agent": "bun examples/http-agent.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/react": "19.2.14",
    "ink": "6.8.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.4",
    "react-devtools-core": "6.1.5"
  }
}
